$(LINUX_ONLY)#!${INSTALL}/bin/${ARCH}/scs-cp-ioc

cd ../..

epicsEnvSet "IOCSH_PS1" "scs-cp-ioc>"

## Register all support components
dbLoadDatabase("dbd/scs-cp-ioc.dbd")
scs_cp_ioc_registerRecordDeviceDriver(pdbbase)

# specify NTP server config file
epicsEnvSet("EPICS_TS_NTP_CONF_FILE","$(NTPCFGFILE)")

## Load record instances
dbLoadRecords("db/m2.db","top=$(SCSTOP):")
dbLoadRecords("db/m2sad.db","top=$(SCSTOP):")
#dbLoadRecords("db/iocAdminRTEMS.db","IOC=$(SCSTOP):iocStats,TODFORMAT=%m/%d/%Y %H:%M:%S")
dbLoadRecords("db/timeProbe.db","top=$(SCSTOP):")

# Configure BANCOMM card
# - set the bc635 Time Provider priority to something other than the default
# or set it to a negative value to disable the bc635 Time Provider
# Must be called before BCconfigure
#bc635TimeSetTpPrio (60)
# - Master ? Simulate ? intPerSecond, intPerTick, timeOffset (microsec)
#BCconfigure (0, 0, 200, 1, 0)

# initialize the xycom 240
drvXy240ConfigOutputInit(1, 32, 0xd000, 0x0000, 0x0003)

# initialize reflective memory
drvVmi5588Config(0xA00000, 0x040000, 0xb0, 0x06)

# connect rm interrupts to handler routines
#rmIntConnect(2, rmISR2)
#rmIntConnect(3, rmISR3)


# This sets the path to the dynamic configuration files directory 
# where the pvload files reside. It also sets the macros to pass to
# pvload()
# It must be called before scsInit()
initSetParameters("$(CNFGDIR)",  "top=$(SCSTOP):, I=$(SCSTOP):inst:")


# old way, do the above instead
#setDataFileDir("$(CNFGDIR)");
#setPvloadMacros("top=$(SCSTOP):, I=$(SCSTOP):inst:")


showDataFileDir
showPvloadMacros

# initialise system, first xycom (via chopInit), then then rest.
# Note: scsInit spawns processGuides which writes to the xycom if compiled
# with the USR C FLAG for TIME_LATENCY, so chopInit goes first.
chopInit
scsInit

## Run this to trace the stages of iocInit
#traceIocInit

#Start EPICS
iocInit

# set debug level for test debugging
#
# TODO: Rippa confirm if these are obsolete, then remove
#debugLevel = 0
#loggingEnable = 1
#CADlogging = 1

#startGuideSim
dbpf "$(SCSTOP):interlockOverride","1"

##M2TS TTL SERVO ON Card0, PORT7, Bit 1, HIGH #####
#xy240_writePortBit (0,7,1,1)

##M2TS CEM POWER ON Card0, PORT7, Bit 0, HIGH #####
#xy240_writePortBit (0,7,0,1)

#dbpf "$(SCSTOP):guideConfigReset.DIR","0"


###### Start any sequence programs
seq &timeSeq, "sys=$(SCSTOP):, top=tcs:"
##seq &timeSeq, "sys=$(SCSTOP):"
##seq &scs_mon "T=$(SCSTOP):, D=$(SCSTOP):"
#seq &tilt_st, "S=$(SCSTOP):tilt:, debug=0"
seq &scs_st, "T=$(SCSTOP):, D=$(SCSTOP):, F=$(SCSTOP):, I=$(SCSTOP):inst:"

zoneset "CLST3"
